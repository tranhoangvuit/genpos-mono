# Copy this file to backend/.env and source it before `make backend`.
# Example: `set -a; source backend/.env; set +a; make backend`

# ----- Server -----
SERVICE_NAME=genpos
SERVER_PORT=3031
ENV=dev

# ----- Database (required) -----
DATABASE_HOST=localhost
DATABASE_PORT=3033
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_DATABASE=genpos_dev
DATABASE_SSL_MODE=disable

# ----- Auth (all optional; dev defaults applied) -----
# IMPORTANT: override AUTH_JWT_SECRET in production — the default is
# rejected when ENV=prod.
AUTH_JWT_SECRET=dev-insecure-change-me
AUTH_ACCESS_TTL=15m
AUTH_REFRESH_TTL_LONG=720h
AUTH_REFRESH_TTL_SHORT=24h
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
AUTH_FRONTEND_ORIGINS=http://localhost:3032,http://localhost:1420,tauri://localhost,http://tauri.localhost,https://tauri.localhost

# ----- DB roles (required) -----
# Consumed by backend/database/bootstrap/bootstrap.sh on every `docker compose up`
# to create/refresh app_runner, app_auth, powersync_user roles.
# POWERSYNC_USER_PASSWORD MUST match the password baked into
# powersync/powersync.yaml (powersync_dev_pw) or PowerSync replication will fail.
APP_RUNNER_PASSWORD=app_runner_dev_pw
APP_AUTH_PASSWORD=app_auth_dev_pw
POWERSYNC_USER_PASSWORD=powersync_dev_pw

# ----- Auth DB pool (required) -----
# Backend opens a second pgx pool with the BYPASSRLS auth role for cross-tenant
# lookups (login/register). Host/port/db reuse DATABASE_*; only user+pw differ.
DATABASE_AUTH_USER=app_auth
DATABASE_AUTH_PASSWORD=app_auth_dev_pw
