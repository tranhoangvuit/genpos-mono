# GenPOS production env. Copy to deploy/.env and fill in.
# `docker compose --env-file .env -f docker-compose.yml up -d`

# ----- Image refs (built + pushed from dev/CI) -----
BACKEND_IMAGE=ghcr.io/your-org/genpos-backend
BACKEND_TAG=latest
FRONTEND_IMAGE=ghcr.io/your-org/genpos-frontend
FRONTEND_TAG=latest

# ----- Postgres -----
POSTGRES_USER=genpos
POSTGRES_PASSWORD=CHANGE_ME_STRONG
POSTGRES_DB=genpos
# Bind to localhost only by default. Set "5432" to expose publicly.
POSTGRES_PORT=127.0.0.1:5432

# ----- Redis -----
REDIS_PASSWORD=CHANGE_ME_STRONG
REDIS_PORT=127.0.0.1:6379

# ----- PowerSync -----
POWERSYNC_VERSION=1.14.0
# Public URL clients hit. Single-domain deployment: append /sync.
POWERSYNC_PUBLIC_URL=https://pos.genpick.com/sync
POWERSYNC_AUDIENCE=powersync-prod
# Shared HS256 secret. Backend signs, PowerSync verifies.
POWERSYNC_JWT_SECRET=CHANGE_ME_STRONG_RANDOM_32B
# Same value, base64-encoded (PowerSync JWKS reads base64 in `k`).
# Generate: printf '%s' "$POWERSYNC_JWT_SECRET" | base64
POWERSYNC_JWT_SECRET_B64=CHANGE_ME_BASE64
# PowerSync admin API token (any random string; required by service).
POWERSYNC_API_TOKEN=CHANGE_ME_RANDOM

# ----- Backend -----
AUTH_JWT_SECRET=CHANGE_ME_STRONG_RANDOM_32B
AUTH_ACCESS_TTL=15m
AUTH_REFRESH_TTL_LONG=720h
AUTH_REFRESH_TTL_SHORT=24h
# Cookie domain. Leave empty for host-only (recommended for single-domain setups).
AUTH_COOKIE_DOMAIN=
# CSV of allowed origins for CORS / refresh. Web client is same-origin so
# only Tauri scheme entries are strictly required, but listing the web origin
# is harmless and explicit.
AUTH_FRONTEND_ORIGINS=https://pos.genpick.com,tauri://localhost,https://tauri.localhost

# ----- Frontend -----
# Baked into client bundle at build time. Single-domain deployment: append /api.
# (Same-origin URL — could also be the relative "/api" if your client supports it.)
PUBLIC_API_BASE_URL=https://pos.genpick.com/api

# ----- Caddy / TLS -----
# Only set for Caddyfile Option C (Let's Encrypt DNS-01 via Cloudflare).
# Cloudflare API token with Zone:DNS:Edit on your zone.
CF_API_TOKEN=
